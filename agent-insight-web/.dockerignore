# =============================================================================
# Docker Ignore for Frontend
# 忽略不需要打包进镜像的文件
# =============================================================================

# 版本控制
.git
.gitignore

# IDE
.idea
.vscode
*.iml

# Node modules（重新 npm install）
node_modules/

# 构建产物（重新构建时会重新生成）
dist/

# 测试
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/__tests__/

# 文档
*.md
docs/

# Docker 相关
Dockerfile*
docker-compose*.yml

# 环境配置
.env
.env.*
*.env

# 其他
*.log
*.txt
performance/

# 前端测试相关
coverage/
