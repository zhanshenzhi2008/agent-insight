# =====================================================================
# agent-insight 环境变量
# 说明：
#  - agent-insight 是 Java/Spring Boot 工程（端口 9280），主要从
#    application.yml 的 ${VAR:default} 占位符里读取环境变量，
#    同时 DynamicDatasourceManager.java 也会读 MYSQL_PORT / POSTGRES_PORT
#    / MONGODB_PORT。
#  - 本文件源自 cogniforge 的 .env，已经合并该文件里所有可复用字段。
#  - agent-insight 自身用不到、但 cogniforge 会用的字段，统一用 # 注释保留，
#    不删除，方便对照或未来复用。
# =====================================================================

# ---------------------------------------------------------------------
# === MongoDB（agent-insight: spring.mongodb.uri / DynamicDatasourceManager）
# ---------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/agent_insight
MONGODB_PORT=27017

# ---------------------------------------------------------------------
# === MySQL（agent-insight: spring.datasource.*）
#   cogniforge 用的是 PostgreSQL，不能直接复用 PostgreSQL 的配置。
# ---------------------------------------------------------------------
# MYSQL_URL=jdbc:mysql://172.18.2.14:3306/llm_agent?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&useUnicode=true&characterEncoding=UTF-8
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=llm_agent
# MYSQL_USERNAME=llm_agent
# MYSQL_PASSWORD=llm_agent

# ---------------------------------------------------------------------
# === Redis（agent-insight: spring.data.redis.*）
#   直接复用 cogniforge 的字段名
# ---------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PWD=

# ---------------------------------------------------------------------
# === AI Providers（agent-insight: spring.ai.*）
#   复用 cogniforge 的 AI_*，并补齐其它 provider 的占位
# ---------------------------------------------------------------------
# --- AI 总开关（agent-insight: agent-insight.ai.enabled） ---
AI_ENABLED=true
AI_PROVIDER=openai
AI_MODEL=gpt-4o

# --- OpenAI（agent-insight: spring.ai.openai.*） ---
# 直接复用 cogniforge 的 AI_BASE_URL / AI_API_KEY / AI_DEFAULT_MODEL
OPENAI_BASE_URL=https://api.xty.app/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Ollama（agent-insight: spring.ai.ollama.*） ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5

# --- DeepSeek（agent-insight: spring.ai.deepseek.*） ---
# DEEPSEEK_API_KEY=EMPTY
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# --- Anthropic（agent-insight: spring.ai.anthropic.*） ---
# ANTHROPIC_API_KEY=EMPTY
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Google GenAI（agent-insight: spring.ai.google.genai.*） ---
# GOOGLE_GENAI_API_KEY=EMPTY
# GOOGLE_GENAI_MODEL=gemini-2.0-flash

# ---------------------------------------------------------------------
# === Agent Insight 自定义路径（agent-insight: agent-insight.log/script.*）
# ---------------------------------------------------------------------
# INSIGHT_LOG_ROOT=
# INSIGHT_SCRIPT_ROOT=

# =====================================================================
# 以下字段来自 cogniforge .env，但 agent-insight 不读取，注释保留
# =====================================================================

# # PostgreSQL Configuration
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5433
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_DB=
# POSTGRES_SSLMODE=disable
#
# # Server (Go gin)
# PORT=8080
# GIN_MODE=debug
#
# # JWT
# JWT_SECRET=cogniforge-secret-key
#
# # Encryption (AES-256-GCM)
# ENCRYPTION_KEY=
#
# # AI Provider (cogniforge 自己的别名，agent-insight 不读)
# AI_DEFAULT_MODEL=gpt-3.5-turbo
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_TITLE=
#
# # Log
# LOG_LEVEL=info
# LOG_FORMAT=json
# UPLOAD_BASE_DIR=
#
# # RAG Python Service
# RAG_PYTHON_URL=http://localhost:8086