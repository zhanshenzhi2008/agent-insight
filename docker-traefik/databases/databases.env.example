# =============================================================================
# databases.env — 数据库服务自身的环境变量
# =============================================================================
# 用途：
#   - 由 docker-compose.yml 引用
#   - 仅供数据库容器内部使用（MySQL root 密码、MongoDB/Redis 自身配置）
#   - 应用连接信息（主机/端口/库名/账号）在 db.env 单独维护（见 ../envs/db.env.example）
#
# 使用方法：
#   cp databases.env.example .env
#   # 编辑 .env，填入 MYSQL_ROOT_PASSWORD 等必填值
#   docker compose --env-file .env up -d
#
# 安全说明：
#   - 不要在此文件写默认密码；每个环境必须显式设置
#   - 不要把 .env 提交到 git
# =============================================================================

# ---------------------------------------------------------------------------
# MySQL
# ---------------------------------------------------------------------------
# 必填：MySQL root 密码（首次启动生效，docker-compose.yml 的 healthcheck 会引用）
MYSQL_ROOT_PASSWORD=

# ---------------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------------
# 备注：MongoDB 不需要初始数据库名，数据库会在首次写入时自动创建
# 如需指定认证，可设置 MONGO_INITDB_ROOT_USERNAME / MONGO_INITDB_ROOT_PASSWORD

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# 可选：Redis 密码（空字符串表示无密码，仅本地/内网使用）
REDIS_PWD=
