# =============================================================================
# 数据库连接配置（envs/db.env）
# =============================================================================
# 用途：
#   - 由 docker-compose.yml 的 backend 服务引用（env_file）
#   - 定义应用连接数据库的主机/端口/库名/账号/密码
#   - 需与 /opt/databases/.env 中的 MYSQL_ROOT_PASSWORD 保持一致
#
# 部署步骤：
#   1. cp envs/db.env.example envs/db.env
#   2. 编辑 envs/db.env，填写真实值
#   3. 容器名（MYSQL_HOST / MONGODB_URI / REDIS_HOST）需与 /opt/databases/
#      docker-compose.yml 的 container_name 对齐
# 格式：
#   - KEY=VALUE
#   - # 开头为注释
#   - 空 KEY（如 MYSQL_PASSWORD=）表示该项未设值（Redis 无密码时）
# =============================================================================

# ------ MySQL ------
# 容器名（mysql，取决于 databases/docker-compose.yml 的 container_name）
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=agent_insight
MYSQL_USERNAME=root
# 必填：与 /opt/databases/.env 中 MYSQL_ROOT_PASSWORD 一致
MYSQL_PASSWORD=

# ------ MongoDB ------
MONGODB_URI=mongodb://mongodb:27017/agent_insight
MONGODB_PORT=27017

# ------ Redis ------
REDIS_HOST=redis
REDIS_PORT=6379
# 如 Redis 未设密码，留空字符串
REDIS_PWD=
