# =============================================================================
# AI 配置（envs/llm.env）
# =============================================================================
# 部署步骤：
#   1. cp envs/llm.env.example envs/llm.env
#   2. AI_ENABLED=false 时可以全部留空
#   3. 开启 AI 时只需填对应 Provider 的 KEY
# 格式：KEY=VALUE
# =============================================================================

# 是否启用 AI 功能（默认 false，按需开启）
AI_ENABLED=false

# Provider 类型：openai | deepseek | ollama
AI_PROVIDER=openai

# ------ OpenAI（AI_PROVIDER=openai 时使用） ------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ------ DeepSeek（AI_PROVIDER=deepseek 时使用） ------
DEEPSEEK_API_KEY=

# ------ Ollama（AI_PROVIDER=ollama 时使用，本地推理） ------
OLLAMA_BASE_URL=
