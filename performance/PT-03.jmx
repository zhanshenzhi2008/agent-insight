<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="5.6.3" jmeter="5.6.3" xmlns="jmeter">
  <hashTree>
    <!-- PT-03: 日志正则搜索，目标 P99 < 3s -->
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="PT-03: 日志正则搜索" enabled="true">
      <stringProp name="TestPlan.comments">目标: P99 &lt; 3s | 场景: 在日志文件中使用正则表达式搜索关键词</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments">
        <collectionProp name="Arguments.arguments"/>
      </elementProp>
    </TestPlan>

    <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="全局变量" enabled="true">
      <collectionProp name="Arguments.arguments">
        <elementProp name="HOST" elementType="Argument">
          <stringProp name="Argument.name">HOST</stringProp>
          <stringProp name="Argument.value">localhost</stringProp>
        </elementProp>
        <elementProp name="PORT" elementType="Argument">
          <stringProp name="Argument.name">PORT</stringProp>
          <stringProp name="Argument.value">9280</stringProp>
        </elementProp>
        <elementProp name="REQUEST_ID" elementType="Argument">
          <stringProp name="Argument.name">REQUEST_ID</stringProp>
          <stringProp name="Argument.value">req_test_001</stringProp>
        </elementProp>
        <elementProp name="USERNAME" elementType="Argument">
          <stringProp name="Argument.name">USERNAME</stringProp>
          <stringProp name="Argument.value">testuser</stringProp>
        </elementProp>
        <elementProp name="KEYWORD" elementType="Argument">
          <stringProp name="Argument.name">KEYWORD</stringProp>
          <stringProp name="Argument.value">\d{3}</stringProp>
        </elementProp>
      </collectionProp>
    </Arguments>

    <hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="PT-03 ThreadGroup" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControllerGui" testclass="LoopController" testname="Loop Controller">
          <intProp name="LoopController.loops">50</intProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">1</stringProp>
        <stringProp name="ThreadGroup.ramp_time">0</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
      </ThreadGroup>

      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /api/v1/requests/{requestId}/log/search" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
            <collectionProp name="Arguments.arguments">
              <elementProp name="username" elementType="HTTPArgument">
                <stringProp name="Argument.name">username</stringProp>
                <stringProp name="Argument.value">${USERNAME}</stringProp>
              </elementProp>
              <elementProp name="keyword" elementType="HTTPArgument">
                <stringProp name="Argument.name">keyword</stringProp>
                <stringProp name="Argument.value">${KEYWORD}</stringProp>
              </elementProp>
              <elementProp name="regex" elementType="HTTPArgument">
                <stringProp name="Argument.name">regex</stringProp>
                <stringProp name="Argument.value">true</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
          <stringProp name="HTTPSampler.port">${PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.path">/api/v1/requests/${REQUEST_ID}/log/search</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <stringProp name="HTTPSampler.implementation">HttpClient4</stringProp>
          <stringProp name="HTTPSampler.response_timeout">10000</stringProp>
        </HTTPSamplerProxy>

        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="响应时间 &lt; 3s" enabled="true">
            <collectionProp name="Asserion.test_strings"/>
            <stringProp name="Assertion.custom_message">响应时间超过 3s</stringProp>
            <intProp name="Assertion.test_type">2</intProp>
            <doubleProp>
              <name>Assertion.expectedResponseTime</name>
              <value>3000</value>
            </doubleProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

        <ResultCollector guiclass="StatGraphVisualizer" testclass="ResultCollector" testname="汇总报告" enabled="true">
          <boolProp name="ResultCollector.error_logging">false</boolProp>
          <objProp>
            <name>saveConfig</name>
            <value class="SaveService">
              <boolProp name="saveTimestamp">false</boolProp>
              <boolProp name="saveLatency">true</boolProp>
              <boolProp name="saveSuccess">true</boolProp>
            </value>
          </objProp>
          <stringProp name="filename"/>
        </ResultCollector>
        <hashTree/>
      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>
